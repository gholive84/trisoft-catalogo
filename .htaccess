# Isola este projeto do WordPress da raiz e roteia tudo via /public/index.php.
# Estratégia: rewrite direto para o front controller (que SEMPRE existe)
# para evitar que o .htaccess do WordPress da raiz intercepte requisições
# que não correspondem a arquivos reais.

Options +FollowSymLinks -Indexes
DirectoryIndex disabled

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Raiz da subpasta -> front controller
    RewriteRule ^$ public/index.php [L]

    # Mapeia URLs públicas de assets/uploads para a pasta real public/
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]
    RewriteRule ^uploads/(.*)$ public/uploads/$1 [L]

    # Se a requisição já é para /public/, deixa o public/.htaccess cuidar
    RewriteCond %{REQUEST_URI} /public/
    RewriteRule ^ - [L]

    # Tudo o mais que não é arquivo real → front controller.
    # IMPORTANTE: rewrite direto para public/index.php (não para public/$1),
    # pois rewrite para path inexistente seria interceptado pelo .htaccess
    # do WordPress no nível superior (que captura URLs não-arquivo/não-pasta).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>

# Bloqueia acesso direto a arquivos sensíveis na raiz do projeto.
# Usamos <Files> simples (sem regex complexa) — mais portável entre
# configurações de Apache/LiteSpeed.
<Files ".env">
    Require all denied
</Files>
<Files "composer.json">
    Require all denied
</Files>
<Files "composer.lock">
    Require all denied
</Files>
<Files ".gitignore">
    Require all denied
</Files>
<Files ".gitattributes">
    Require all denied
</Files>
<Files "README.md">
    Require all denied
</Files>
<FilesMatch "^\.env\.">
    Require all denied
</FilesMatch>
