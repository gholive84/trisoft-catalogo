# ============================================================
# Catálogo Trisoft — variáveis de ambiente
# Copie para .env e preencha. NUNCA commitar o .env.
# ============================================================

APP_NAME="Catálogo Trisoft"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://trisoft.com.br/catalogo2
# BASE_URL é o prefixo após o domínio. Em produção subpasta: "/catalogo2"
# Quando promover para a raiz: ""
BASE_URL=/catalogo2
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# ----- Banco de dados (MySQL) -----
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=db17v4gywlznyn
DB_USERNAME=ugjpjb86ajvr9
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ----- Sessão e segurança -----
SESSION_NAME=trisoft_session
SESSION_LIFETIME_MINUTES=120
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax
APP_KEY=

# ----- SMTP (PHPMailer) -----
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@trisoft.com.br
MAIL_FROM_NAME="Catálogo Trisoft"
# Vendedores recebem notificações de novos orçamentos
MAIL_SELLERS_TO=vendas@trisoft.com.br

# ----- Banco WordPress legado (para script de migração) -----
WP_DB_HOST=localhost
WP_DB_PORT=3306
WP_DB_DATABASE=
WP_DB_USERNAME=
WP_DB_PASSWORD=
WP_DB_PREFIX=wp_

# ----- Uploads -----
UPLOAD_MAX_BYTES=8388608
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,image/gif

# ----- Carrinho abandonado -----
ABANDONED_CART_DAYS=3
QUOTE_EXPIRATION_DAYS=15
